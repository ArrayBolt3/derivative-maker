## Using specific codenames (for example: "trixie") rather than generic code
## names (for example: "stable") because grml-debootstrap did not support
## generic code names for --release. See also:
## github.com/grml/grml-debootstrap/issues/37

## Using contrib, because it contains virtualbox-guest-x11.

## Added deb-src so source package can also be downloaded.

deb http://127.0.0.1:9977/debian-security trixie-security main contrib non-free non-free-firmware
deb-src http://127.0.0.1:9977/debian-security trixie-security main contrib non-free non-free-firmware

deb http://127.0.0.1:9977/debian trixie-updates main contrib non-free non-free-firmware
deb-src http://127.0.0.1:9977/debian trixie-updates main contrib non-free non-free-firmware

## TODO: Can be out-commented for debian trixie, required for getting newer
## debhelper in help-steps/pbuilder-chroot-script-main
deb http://127.0.0.1:9977/debian trixie-backports main contrib non-free non-free-firmware
deb-src http://127.0.0.1:9977/debian trixie-backports main contrib non-free non-free-firmware

## TODO: fasttrack doesn't have anything in it in Trixie yet
#deb [signed-by=/usr/share/keyrings/fasttrack-archive-keyring.gpg] http://127.0.0.1:9977/debian-fasttrack trixie-fasttrack main contrib non-free
#deb-src [signed-by=/usr/share/keyrings/fasttrack-archive-keyring.gpg] http://127.0.0.1:9977/debian-fasttrack trixie-fasttrack main contrib non-free

#deb [signed-by=/usr/share/keyrings/fasttrack-archive-keyring.gpg] http://127.0.0.1:9977/debian-fasttrack trixie-backports-staging main contrib non-free
#deb-src [signed-by=/usr/share/keyrings/fasttrack-archive-keyring.gpg] http://127.0.0.1:9977/debian-fasttrack trixie-backports-staging main contrib non-free

deb http://127.0.0.1:9977/debian trixie main contrib non-free non-free-firmware
deb-src http://127.0.0.1:9977/debian trixie main contrib non-free non-free-firmware

## Last entry must be a "good" one since dist_build_apt_stable_release is set
## from last line starting with 'deb'. Should be "trixie" (stable) and not
## backports or something else.
